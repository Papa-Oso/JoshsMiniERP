# Server
PORT=5174
HOST=127.0.0.1
ERP_API_TOKEN=
DATA_FILE=data/inventory.json
DATABASE_URL=

# Use json for local testing. Set DATABASE_URL and use postgres only when you intentionally
# run against an existing Postgres database, such as Google Cloud SQL.
STORE_DRIVER=json

# Shopify Admin API
# Use the permanent myshopify.com domain for the real store, not your public custom domain.
# Example: joshswidgets.myshopify.com
SHOPIFY_SHOP_DOMAIN=

# Option A: fixed Admin API access token, if you generated one.
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Option B: Dev Dashboard app credentials for Shopify's client credentials grant.
# Client ID belongs to the app. Client secret may be labeled Client secret, API secret key,
# app secret, or SHOPIFY_API_SECRET depending on Shopify's screen/template.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Keep this aligned with the Admin API version used by the inventory adapter.
SHOPIFY_API_VERSION=2026-07

# eBay Sell Inventory API
# Use production for live eBay or sandbox for test accounts.
EBAY_ENVIRONMENT=production
EBAY_ACCESS_TOKEN=
EBAY_REFRESH_TOKEN=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# eBay calls this value redirect_uri in OAuth requests, but it is the RuName
# from your Application Keys page, not a normal https callback URL.
EBAY_RUNAME=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_TOKEN_FILE=data/ebay-auth.json

# Etsy Open API v3
# Etsy shows the keystring and shared secret separately.
ETSY_KEYSTRING=
ETSY_SHARED_SECRET=

# Must exactly match an HTTPS redirect URI registered in the Etsy app.
# Example: https://joshswidgets.com/etsy/callback
ETSY_REDIRECT_URI=

# Usually leave these blank. The CLI OAuth helper saves tokens to ETSY_TOKEN_FILE.
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_TOKEN_FILE=data/etsy-auth.json
